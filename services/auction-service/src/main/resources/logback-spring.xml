<?xml version="1.0" encoding="UTF-8"?>
<configuration>
  <include resource="org/springframework/boot/logging/logback/defaults.xml"/>

  <springProperty name="APP_NAME" source="spring.application.name" defaultValue="unknown"/>
  <property name="CONSOLE_LOG_PATTERN"
            value="%clr(%d{yyyy-MM-dd'T'HH:mm:ss.SSSXXX}){faint} %clr(%5p) %clr(${PID:- }){magenta} %clr(---){faint} %clr([%15.15t]){faint} %clr(service=${APP_NAME} auctionId=%X{auctionId:-none}){cyan} %clr(%-40.40logger{39}){cyan} %clr(:){faint} %m%n${LOG_EXCEPTION_CONVERSION_WORD:-%wEx}"/>

  <include resource="org/springframework/boot/logging/logback/console-appender.xml"/>

  <appender name="LOKI" class="com.github.loki4j.logback.Loki4jAppender">
    <http>
      <url>${LOKI_URL:-http://localhost:3100}/loki/api/v1/push</url>
    </http>
    <format>
      <label>
        <pattern>service=${APP_NAME},host=${HOSTNAME:-local},auctionId=%X{auctionId:-none}</pattern>
      </label>
      <message class="com.github.loki4j.logback.JsonLayout"/>
    </format>
  </appender>

  <root level="INFO">
    <appender-ref ref="CONSOLE"/>
    <appender-ref ref="LOKI"/>
  </root>

  <logger name="com.bankrupang" level="DEBUG"/>
</configuration>
