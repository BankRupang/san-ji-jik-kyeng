{
  "realm": "sanjijk",
  "displayName": "산지직경",
  "enabled": true,
  "sslRequired": "none",
  "registrationAllowed": false,
  "loginWithEmailAllowed": true,
  "duplicateEmailsAllowed": false,
  "verifyEmail": false,
  "accessTokenLifespan": 86400,
  "refreshTokenMaxReuse": 0,

  "roles": {
    "realm": [
      { "name": "BUYER",   "description": "구매자" },
      { "name": "SELLER",  "description": "판매자" },
      { "name": "MANAGER", "description": "중간 관리자" },
      { "name": "MASTER",  "description": "마스터 관리자" }
    ]
  },

  "clients": [
    {
      "clientId": "user-service",
      "name": "User Service",
      "description": "회원가입/로그인 및 Admin API 호출 클라이언트",
      "enabled": true,
      "publicClient": false,
      "clientAuthenticatorType": "client-secret",
      "secret": "dev-secret-sanjijk-1234",
      "serviceAccountsEnabled": true,
      "authorizationServicesEnabled": false,
      "standardFlowEnabled": false,
      "implicitFlowEnabled": false,
      "directAccessGrantsEnabled": true,
      "protocolMappers": [
        {
          "name": "role-attribute-mapper",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-attribute-mapper",
          "config": {
            "user.attribute": "role",
            "claim.name": "role",
            "jsonType.label": "String",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "userinfo.token.claim": "true"
          }
        }
      ]
    }
  ],

  "requiredActions": [
    {
      "alias": "VERIFY_PROFILE",
      "name": "Verify Profile",
      "providerId": "VERIFY_PROFILE",
      "enabled": false,
      "defaultAction": false,
      "priority": 90
    }
  ],

  "users": [
    {
      "username": "service-account-user-service",
      "serviceAccountClientId": "user-service",
      "enabled": true,
      "clientRoles": {
        "realm-management": [
          "manage-users",
          "view-users"
          ]
      }
    }
  ],

  "components": {
    "org.keycloak.userprofile.UserProfileProvider": [
      {
        "providerId": "declarative-user-profile",
        "subComponents": {},
        "config": {
          "kc.user.profile.config": [
            "{\"attributes\":[{\"name\":\"username\"},{\"name\":\"email\"},{\"name\":\"firstName\"},{\"name\":\"lastName\"},{\"name\":\"role\",\"displayName\":\"Role\",\"permissions\":{\"view\":[\"admin\",\"user\"],\"edit\":[\"admin\"]}}]}"
          ]
        }
      }
    ]
  }
}
