{
  "title": "Sanji - AWS 인프라 모니터링",
  "uid": "sanji-cloudwatch",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "1m",
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "panels": [
    {
      "id": 1,
      "title": "ECS CPU 사용률 (%)",
      "type": "timeseries",
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 12,
        "h": 8
      },
      "datasource": {
        "type": "cloudwatch",
        "uid": "cloudwatch"
      },
      "targets": [
        {
          "refId": "A",
          "region": "ap-northeast-2",
          "namespace": "ECS/ContainerInsights",
          "metricName": "CpuUtilized",
          "dimensions": {
            "ClusterName": [
              "sanji-prod-cluster"
            ]
          },
          "statistic": "Average",
          "period": "60",
          "matchExact": false,
          "queryMode": "Metrics",
          "metricQueryType": 0,
          "metricEditorMode": 0
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100
        }
      }
    },
    {
      "id": 2,
